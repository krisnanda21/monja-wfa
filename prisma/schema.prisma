generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique @default(cuid())
  password  String   @default("password123")
  name      String
  position  String
  subbagian String   // Enum conceptually: 'Penkom', 'Bangkom', 'Pembinaan', 'Semua'
  role      String   // Enum conceptually: 'Admin', 'AnggotaTim', 'KetuaTim', 'Dalnis', 'Subkoordinator', 'Koordinator'

  // Relations
  tasksAsKetuaTim       Task[] @relation("KetuaTimTasks")
  tasksAsDalnis         Task[] @relation("DalnisTasks")
  tasksAsSubkoordinator Task[] @relation("SubkoordinatorTasks")
  
  assignedTasks         TaskAssignment[]
  uploadedFiles         TaskFile[]
  reviewsMade           TaskReview[]
  notifications         Notification[]
}

model Task {
  id                  String   @id @default(uuid())
  title               String
  description         String
  subbagian           String   // Enum: Penkom, Bangkom, Pembinaan
  startDate           DateTime
  endDate             DateTime
  status              String   // Enum: SedangDikerjakan, ApprovalKetuaTim, RejectKetuaTim, ApprovalDalnis, RejectDalnis, ApprovalSubkoor, RejectSubkoor, ApprovalKoordinator, RejectKoordinator, Completed
  assignmentLetterUrl String?

  ketuaTimId          String
  ketuaTim            User     @relation("KetuaTimTasks", fields: [ketuaTimId], references: [id])

  dalnisId            String
  dalnis              User     @relation("DalnisTasks", fields: [dalnisId], references: [id])

  subkoordinatorId    String
  subkoordinator      User     @relation("SubkoordinatorTasks", fields: [subkoordinatorId], references: [id])

  assignments         TaskAssignment[]
  files               TaskFile[]
  reviews             TaskReview[]
}

model TaskAssignment {
  id      String @id @default(uuid())
  taskId  String
  userId  String

  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskFile {
  id         String   @id @default(uuid())
  taskId     String
  uploaderId String
  fileUrl    String
  fileType   String   // File, Link, etc.
  notes      String?
  status     String   @default("Pending") // Pending, Approved, Rejected
  createdAt  DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model TaskReview {
  id         String   @id @default(uuid())
  taskId     String
  stage      String   // KetuaTim, Dalnis, Subkoordinator, Koordinator
  reviewerId String
  isApproved Boolean
  notes      String?
  timestamp  DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer   User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  timestamp DateTime @default(now())
  taskId    String?  // Optional reference to a task

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
